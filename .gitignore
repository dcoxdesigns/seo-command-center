# Keep real client data out of the demo repo — sample/* files are the exceptions
data/**/*.csv
data/**/*.json
data/**/*.xlsx
!data/**/sample-*.csv
!data/**/sample-*.json

# Real client configs (the .example file is tracked)
config/*.yml
config/*.yaml
!config/*.example.yml

# Generated reports (client-named)
reports/*.md
!reports/.gitkeep

# Real per-client folders (data/reports/client-facts) — _template is the tracked scaffold
clients/*/
!clients/_template/
!clients/_template/**

# Business info (pricing, contracts) — private, never belongs in this public demo repo
business/

# AI visibility tracker's own SQLite DB and raw response logs — real client
# run data, not source. The tool code itself stays tracked.
tools/ai-visibility-tracker/data/

# Local env / secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
