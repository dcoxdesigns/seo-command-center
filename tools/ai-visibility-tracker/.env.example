# Copy this file to .env and fill in real keys. .env is gitignored — never commit real keys.
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Optional overrides — defaults are set in tracker/platforms/*.py
# OPENAI_MODEL=gpt-4o
# PERPLEXITY_MODEL=sonar
# GEMINI_MODEL=gemini-2.0-flash

# Required for export_citability.py — must point at the SAME Upstash Redis
# instance as smallfactory5-site (copy the values from that project's
# .env.local), so the page-review tool can read what this tool exports.
UPSTASH_REDIS_REST_KV_REST_API_URL=
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=
